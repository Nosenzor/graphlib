# Doxygen over the public headers only (docs/DESIGN.md is the spec digest;
# internal src/ headers are deliberately absent). Configured by the `docs`
# CMake target.
PROJECT_NAME           = "graphlib"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "A modern C++ plotting library that mimics matplotlib"
OUTPUT_DIRECTORY       = "@GRAPHLIB_DOCS_OUT@"
INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/include" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/README.md"
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/README.md"
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"
STRIP_FROM_INC_PATH    = "@CMAKE_CURRENT_SOURCE_DIR@/include"
EXTRACT_ALL            = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
HTML_OUTPUT            = api
HTML_COLORSTYLE        = LIGHT
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
FULL_PATH_NAMES        = YES
SOURCE_BROWSER         = YES
ALPHABETICAL_INDEX     = YES
IMAGE_PATH             = "@CMAKE_CURRENT_SOURCE_DIR@/docs/gallery"
EXAMPLE_PATH           = "@CMAKE_CURRENT_SOURCE_DIR@/examples"
