@PACKAGE_INIT@

# graphlib was built without mandatory dependencies; the interactive GLFW
# backend is the only optional one and is baked in at build time.
if(@GRAPHLIB_INTERACTIVE@)
    include(CMakeFindDependencyMacro)
    find_dependency(glfw3)
    find_dependency(OpenGL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/graphlibTargets.cmake")
check_required_components(graphlib)
